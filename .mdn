🔗 Import System & Aliases
Vite Configuration (vite.config.js)
export default defineConfig({
  resolve: {
    alias: {
      '@': '/src',
      '@components': '/src/components',
      '@hooks': '/src/hooks',
      '@stores': '/src/stores',
      '@data': '/src/data',
      '@utils': '/src/utils',
      '@styles': '/src/styles',
    },
  },
})
Import Examples
1. Using Aliases
// ✅ Recommended - Using aliases
import useCosmicStore from '@stores/useCosmicStore'
import { SECTIONS } from '@utils/constants'
import { PortalLoader } from '@components/sections'
import CosmicInput from '@components/inputs/CosmicInput'
2. Relative Imports
// ✅ Alternative - Relative paths
import useCosmicStore from '../stores/useCosmicStore'
import { SECTIONS } from '../utils/constants'
import PortalLoader from '../components/sections/PortalLoader'
3. Index File Exports
// From src/components/ui/index.js
export { default as QuantumCursor } from './QuantumCursor'
export { default as ParticleBackground } from './ParticleBackground'

// Usage
import { QuantumCursor, ParticleBackground } from '@components/ui'
🌊 Application Flow
1. Entry Point (
main.jsx
)
import React from 'react'
import ReactDOM from 'react-dom/client'
import App from './App.jsx'

// Import all styles
import './styles/globals.css'
import './styles/animations.css'
import './styles/cosmic-theme.css'

ReactDOM.createRoot(document.getElementById('root')).render(
  <React.StrictMode>
    <App />
  </React.StrictMode>,
)
2. Main App Component (
App.jsx
)
import { useEffect } from 'react'
import { AnimatePresence, motion } from 'framer-motion'
import { PortalLoader, CosmicWelcome } from '@components/sections'
import useCosmicStore from '@stores/useCosmicStore'
import { SECTIONS } from '@utils/constants'

function App() {
  const { isLoading, currentSection } = useCosmicStore()
  
  return (
    <div className="relative min-h-screen bg-cosmic-void">
      <AnimatePresence mode="wait">
        {isLoading && <PortalLoader />}
        {currentSection === SECTIONS.WELCOME && <CosmicWelcome />}
        {/* Other sections... */}
      </AnimatePresence>
    </div>
  )
}
3. Application States Flow
LOADER → WELCOME → FORM → READING → RESULTS
   ↓        ↓        ↓        ↓        ↓
Loading   Landing   Multi-   Cosmic   Display
Screen    Page      Step     Analysis Results
                    Form
🏗 Component Architecture
Component Categories
1. Sections (@components/sections)
Main application screens and layouts

// PortalLoader.jsx - 3D animated loading screen
import { PortalLoader } from '@components/sections'

// CosmicWelcome.jsx - Landing page
import { CosmicWelcome } from '@components/sections'
2. UI Components (@components/ui)
Reusable interface elements

// Particle effects, cursors, modals
import { 
  QuantumCursor, 
  ParticleBackground, 
  FloatingOrbs 
} from '@components/ui'
3. Input Components (@components/inputs)
Form controls with cosmic styling

import CosmicInput from '@components/inputs/CosmicInput'
import StardustSelect from '@components/inputs/StardustSelect'
4. Cards (@components/cards)
Result display cards

import { 
  ZodiacIdentityCard, 
  SoulCompatibilityCard 
} from '@components/cards'
Component Props Pattern
// Typical component structure
const CosmicInput = ({
  label,
  value,
  onChange,
  glowColor = 'purple', // 'purple' | 'gold' | 'pink' | 'cyan'
  className = '',
  ...props
}) => {
  // Component logic
  return <input className={cn('cosmic-input', className)} {...props} />
}
🗃 State Management
Store Structure
1. Cosmic Store (@stores/useCosmicStore)
Main application state

const useCosmicStore = create((set, get) => ({
  // Navigation
  isLoading: true,
  currentSection: SECTIONS.LOADER,
  
  // Form data
  formData: {
    firstName: '',
    lastName: '',
    gender: '',
    // ...
  },
  
  // Actions
  goToWelcome: () => set({ currentSection: SECTIONS.WELCOME }),
  updateFormData: (data) => set(state => ({ 
    formData: { ...state.formData, ...data } 
  })),
}))
2. UI Store (@stores/useUIStore)
UI preferences and settings

const useUIStore = create(persist((set) => ({
  theme: 'dark',
  soundEnabled: false,
  particlesEnabled: true,
  
  setTheme: (theme) => set({ theme }),
  toggleSound: () => set(state => ({ 
    soundEnabled: !state.soundEnabled 
  })),
})))
Usage in Components
function MyComponent() {
  // Subscribe to specific state
  const { isLoading, goToWelcome } = useCosmicStore()
  const theme = useUIStore(state => state.theme)
  
  // Use in component
  if (isLoading) return <Loader />
  
  return (
    <div data-theme={theme}>
      <button onClick={goToWelcome}>Continue</button>
    </div>
  )
}
🎨 Styling System
Tailwind Configuration
Custom cosmic color palette and utilities defined in tailwind.config.js:

theme: {
  extend: {
    colors: {
      cosmic: {
        void: '#050510',
        purple: {
          500: '#8b5cf6',
          600: '#7c3aed',
          // ...
        },
        gold: {
          DEFAULT: '#ffd54f',
          light: '#ffe082',
          dark: '#ff8f00',
        },
      },
    },
    animation: {
      'float': 'float 6s ease-in-out infinite',
      'pulse-glow': 'pulseGlow 3s ease-in-out infinite',
      // ...
    },
  },
}
CSS Architecture
1. Global Styles (
globals.css
)
@tailwind base;
@tailwind components;
@tailwind utilities;

@layer components {
  .glass {
    @apply bg-white/5 backdrop-blur-xl border border-white/10;
  }
  
  .text-gradient-gold {
    background-image: linear-gradient(135deg, #ffd54f 0%, #ff8f00 100%);
    @apply bg-clip-text text-transparent;
  }
}
2. Animations (
animations.css
)
@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-20px) rotate(2deg); }
}

.celestial-orbit {
  animation: celestialOrbit var(--orbit-duration, 20s) linear infinite;
}
3. Theme Variables (
cosmic-theme.css
)
[data-theme="dark"] {
  --bg-primary: #050510;
  --text-primary: #ffffff;
}

[data-theme="light"] {
  --bg-primary: #f0e6ff;
  --text-primary: #1a0533;
}
🚀 Setup & Installation
Prerequisites
Node.js 18+
npm or yarn
Installation Steps
Clone & Install
git clone <repository-url>
cd cosmic-soul-reader
npm install
Development Server
npm run dev
# Server runs on http://localhost:3000
Build for Production
npm run build
npm run preview
Available Scripts
{
  "scripts": {
    "dev": "vite",
    "build": "vite build", 
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx"
  }
}
🔄 Development Workflow
Component Development Pattern
Create Component
// src/components/ui/NewComponent.jsx
import { motion } from 'framer-motion'
import { cn } from '@utils/helpers'

const NewComponent = ({ className, ...props }) => {
  return (
    <motion.div 
      className={cn('base-styles', className)}
      {...props}
    >
      {/* Component content */}
    </motion.div>
  )
}

export default NewComponent
Export from Index
// src/components/ui/index.js
export { default as NewComponent } from './NewComponent'
Use in App
import { NewComponent } from '@components/ui'
State Management Pattern
Add to Store
// In useCosmicStore.js
const useCosmicStore = create((set) => ({
  newState: null,
  setNewState: (value) => set({ newState: value }),
}))
Use in Component
const { newState, setNewState } = useCosmicStore()
Styling Pattern
Use Tailwind Classes
<div className="glass rounded-3xl p-6 hover:bg-white/10">
Custom CSS for Complex Animations
/* In animations.css */
@keyframes customAnimation {
  /* keyframes */
}
.custom-class {
  animation: customAnimation 2s ease-in-out infinite;
}
